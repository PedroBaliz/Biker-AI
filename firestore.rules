rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened Rules for Users Collection
    match /users/{email} {
      // Enforce that the user is logged in, and they are accessing their own document
      allow read, write: if request.auth != null 
        && request.auth.token.email.lower() == email.lower();
      
      // Let the coach access any user's document for plan management and backup/restores
      allow read, write: if request.auth != null 
        && request.auth.token.email.lower() == "pedro.bramos@sempreceub.com";
    }
  }
}
