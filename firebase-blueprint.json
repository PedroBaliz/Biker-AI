{
  "collections": {
    "users": {
      "description": "User accounts, athlete profiles, coaching plan details, and historical data.",
      "documents": {
        "email": {
          "fields": {
            "email": { "type": "string", "required": true },
            "password": { "type": "string", "required": false },
            "profile": { "type": "map", "required": true },
            "chatHistory": { "type": "array", "required": false },
            "plan": { "type": "map", "required": false }
          }
        }
      }
    }
  }
}
